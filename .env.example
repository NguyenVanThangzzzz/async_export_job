# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/async_export

# Redis
REDIS_URL=redis://localhost:6379

# Email (SMTP) — only required in production; dev uses Ethereal auto-account
SMTP_HOST=smtp.gmail.com
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Sender address for export notification emails
EMAIL_FROM=your-email@gmail.com

# Optional: override the default mock user ID
MOCK_USER_ID=mock-user-001

# Optional: log level (default: info)
LOG_LEVEL=info
